# Скопируй в .env и при необходимости измени host/port API.
VITE_API_BASE=http://127.0.0.1:8000
# Оркестратор (страница /orch). В dev можно не задавать — тогда используется прокси Vite
# /orchestrator → http://127.0.0.1:8030 (см. vite.config.js). Явный URL обходит прокси.
# VITE_ORCHESTRATOR_BASE=
# VITE_ORCHESTRATOR_BASE=http://127.0.0.1:8030
